# ==========================================================================
#  Chapitre 3 — Variables d'environnement (copier en .env.local)
# ==========================================================================

# --- Supabase ---------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://votre-projet.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="votre-anon-key-publique"
# ⚠️ Serveur uniquement, ne jamais exposer côté client.
SUPABASE_SERVICE_ROLE_KEY="votre-service-role-key-secrete"

# --- Site -------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_ROOT_DOMAIN="chapitre3.fr"

# --- Contact : webhook Discord (OPTIONNEL) ---------------------------------
# Si vide, le site n'envoie rien dans Discord (le message reste enregistré
# dans l'admin). Dès qu'une URL est renseignée, l'envoi s'active.
CONTACT_DISCORD_WEBHOOK_URL=""

# --- Contact : CAPTCHA Cloudflare Turnstile (OPTIONNEL) --------------------
# Si vide, le formulaire fonctionne SANS CAPTCHA. Dès que les deux clés sont
# renseignées, le CAPTCHA s'active automatiquement.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
